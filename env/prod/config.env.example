# Non-secret config used to create the GKE ConfigMap
SESSION_NAME=helpudoc.sid
SESSION_TTL_SECONDS=604800
AUTH_MODE=hybrid
SESSION_COOKIE_DOMAIN=.lc-demo.com
SESSION_COOKIE_DOMAIN=.lc-demo.com
POSTGRES_DB=helpudoc
POSTGRES_USER=helpudoc
S3_BUCKET_NAME=helpudoc
# Public URL that browsers should use to fetch objects.
# Use a same-origin path so it works behind HTTPS and avoids mixed-content.
S3_PUBLIC_BASE_URL=/helpudoc
S3_FORCE_PATH_STYLE=true
WORKSPACE_ROOT=/app/workspaces
RAG_OFFLINE=true
LLM_MODEL=gemini-3-flash-preview
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=https://lc-demo.com/api/auth/google/callback
GOOGLE_OAUTH_POST_LOGIN_REDIRECT=https://lc-demo.com/login
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/bigquery
