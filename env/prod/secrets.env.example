# Secrets used to create the GKE Secret
SESSION_SECRET=change-me
POSTGRES_PASSWORD=helpudoc
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
RAG_LLM_API_KEY=YOUR_GEMINI_API_KEY
AGENT_JWT_SECRET=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_TOKEN_ENCRYPTION_KEY=

# Langfuse v3 (GKE). CLICKHOUSE_PASSWORD: ClickHouse superuser password (must match 44-clickhouse).
CLICKHOUSE_PASSWORD=change-me-clickhouse
# openssl rand -base64 32 (use strong values in production)
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
# openssl rand -hex 32 — must be exactly 64 hex characters
LANGFUSE_ENCRYPTION_KEY=
# Project API keys (must match LANGFUSE_INIT_* if using headless init); agent reads the same keys for tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_INIT_USER_PASSWORD=
