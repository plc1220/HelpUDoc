# Local development env (export before running backend/agent/frontend)
# Usage:
#   set -a; source env/local/dev.env; set +a
#   (or) ENV_FILE=../env/local/dev.env npm run dev (backend)

NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me
SESSION_NAME=helpudoc.sid
SESSION_TTL_SECONDS=604800
AUTH_MODE=headers
DEFAULT_USER_ID=local-admin@local.com
DEFAULT_USER_NAME=admin
DEFAULT_USER_EMAIL=admin@local.com
AGENT_URL=http://localhost:8001

REDIS_URL=redis://localhost:6379
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=helpudoc
POSTGRES_USER=helpudoc
POSTGRES_PASSWORD=helpudoc
DATABASE_URL=postgres://helpudoc:helpudoc@localhost:5432/helpudoc
DATABASE_SSL=false

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=helpudoc
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/helpudoc
S3_FORCE_PATH_STYLE=true

WORKSPACE_ROOT=backend/workspaces
SKILLS_ROOT=skills
AGENT_CONFIG_PATH=agent/config/runtime.yaml
ADMIN_EMAILS=admin@local.com
RAG_OFFLINE=true

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
RAG_LLM_API_KEY=YOUR_GEMINI_API_KEY
LLM_MODEL=gemini-3-flash-preview
VITE_GOOGLE_CLIENT_ID=16646144790-fvdv7liepgo18aiu20n3btmdr56l33pq.apps.googleusercontent.com
VITE_AUTH_MODE=headers
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_POST_LOGIN_REDIRECT=http://localhost:5173/login
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/bigquery
# Generate a 32-byte base64url key, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OAUTH_TOKEN_ENCRYPTION_KEY=
